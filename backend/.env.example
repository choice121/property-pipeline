# ── Core (required — app will not start without these) ────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# ── Publishing / ImageKit (required for photo uploads) ────────────────────────
IMAGEKIT_PUBLIC_KEY=public_xxxx
IMAGEKIT_PRIVATE_KEY=private_xxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-imagekit-id

# ── Optional features ─────────────────────────────────────────────────────────
SUPABASE_ANON_KEY=your-anon-jwt
DEEPSEEK_API_KEY=sk-xxxx
CHOICE_LANDLORD_ID=uuid-of-landlord-row-in-supabase
